# Public site URL used for social previews.
NEXT_PUBLIC_SITE_URL="https://long-cha.vercel.app"

# Admin password used by /admin and /api/admin/*.
# Change this before deploying.
ADMIN_PASSWORD="change-this-password"

# Supabase server-side credentials.
# Use the Project URL and service role key from Supabase.
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
SUPABASE_STORAGE_BUCKET="menu-images"
